# Variables de entorno — Portal UNISANGIL Yopal Backend
# Copia este archivo como .env y rellena los valores reales.
# ¡NUNCA subas el archivo .env al repositorio!

# Clave de API de Anthropic (obtenla en https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Puerto del servidor (por defecto: 3001)
PORT=3001
